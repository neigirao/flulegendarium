# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# ---------------------------------------------------------------------------
# Supabase — obrigatório
# ---------------------------------------------------------------------------
# URL do projeto (encontre em: Settings > API > Project URL)
VITE_SUPABASE_URL="https://<project-id>.supabase.co"

# Chave anon/pública (Settings > API > Project API keys > anon public)
VITE_SUPABASE_PUBLISHABLE_KEY=""

# ID do projeto (parte da URL, ex: hafxruwnggivy...)
VITE_SUPABASE_PROJECT_ID=""

# ---------------------------------------------------------------------------
# Autenticação Google — obrigatório para login via One Tap
# ---------------------------------------------------------------------------
# Client ID OAuth 2.0 (console.cloud.google.com > Credenciais)
VITE_GOOGLE_CLIENT_ID=""

# ---------------------------------------------------------------------------
# Analytics — opcional
# ---------------------------------------------------------------------------
# Google Analytics 4 Measurement ID (ex: G-XXXXXXXXXX)
# Se ausente, usa o fallback hardcoded em use-analytics.ts
VITE_GA4_ID=""

# ---------------------------------------------------------------------------
# Feature flags — opcional
# ---------------------------------------------------------------------------
# Define "true" para ativar a rota /design-system em produção
# (ativa automaticamente em modo DEV)
VITE_ENABLE_DESIGN_SYSTEM=""
